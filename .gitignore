/public/swe-worker-*.js.map
/public/worker-*.js
/public/worker-*.js.map
/public/fallback-*.js
/public/fallback-*.js.map

# git bundles / patch archives (used for branch transfers, not source)
*.bundle
*-patches.zip

# local AI assistant config / guidance (kept out of the repo)
CLAUDE.md
.claude/
