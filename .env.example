# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase dashboard → Settings → API

# Project URL  (used by the app AND scripts)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# anon / public key  (safe to expose — used by the browser client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# service_role key  (NEVER commit — used only by admin scripts, not the app)
# Supabase dashboard → Settings → API → "service_role" key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── football-data.org (optional — only needed to seed player data) ───────────
# Free account at https://www.football-data.org → My Account → API Keys
FOOTBALL_API_TOKEN=your-football-data-token
FOOTBALL_DATA_API_KEY=your-football-data-token

# ─── Kickoffapi (optional — live lineups, results, injuries, scorers) ─────────
# https://kickoffapi.com — host api.kickoffapi.com, header x-api-key
KICKOFF_API_KEY=your-kickoffapi-key
# KICKOFF_LEAGUE=1
# KICKOFF_SEASON=2026

# Guards the scheduled sync endpoints (GitHub Actions sends this as a Bearer token)
CRON_SECRET=any-random-string

# ─── API-FOOTBALL (optional — alternative richer player stats backfill) ───────
# Free key (direct api-sports.io, NOT RapidAPI): https://dashboard.api-football.com
# Used by scripts/fetch-player-stats.ts. Host: v3.football.api-sports.io
API_FOOTBALL_KEY=your-api-sports-key
# API_FOOTBALL_LEAGUE=1
# API_FOOTBALL_SEASON=2026
