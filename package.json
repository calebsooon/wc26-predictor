{
  "name": "matchday",
  "description": "Private World Cup 2026 prediction league with live scoring, leaderboard and prize pool",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "repo:check": "tsx scripts/repo-check.ts",
    "check": "npm run repo:check && npm run lint && npm run typecheck && npm test && npm run build",
    "setup:check": "tsx --env-file=.env.local scripts/setup-check.ts",
    "bootstrap:admin": "tsx --env-file=.env.local scripts/grant-admin.ts",
    "data:players": "tsx --env-file=.env.local scripts/fetch-players.ts",
    "data:enrich": "tsx --env-file=.env.local scripts/fetch-wikidata-players.ts",
    "data:photos": "tsx --env-file=.env.local scripts/cache-player-photos.ts",
    "data:stats": "tsx --env-file=.env.local scripts/fetch-player-stats.ts",
    "data:fill-photos": "tsx --env-file=.env.local scripts/fill-missing-photos.ts"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "flag-icons": "^7.5.0",
    "framer-motion": "^12.40.0",
    "next": "^15.5.19",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "postcss": "$postcss",
    "esbuild": "0.28.1"
  }
}
